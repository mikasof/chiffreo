# ============================================
# Chiffreo MVP - Configuration
# ============================================
# Copier ce fichier vers .env et remplir les valeurs

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chiffreo
DB_USER=root
DB_PASS=root

# OpenAI API
OPENAI_API_KEY=sk-votre-cle-api-ici

# SerpAPI (pour recherche de prix réels)
# Inscription gratuite : https://serpapi.com (100 recherches/mois gratuites)
SERPAPI_KEY=votre-cle-serpapi-ici

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Limites
RATE_LIMIT_PER_MINUTE=30
MAX_UPLOAD_SIZE_MB=10

# Stockage
STORAGE_PATH=storage

# Push Notifications (VAPID keys)
# Générer avec: npx web-push generate-vapid-keys
# Ou: https://vapidkeys.com/
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@chiffreo.fr
