# ============================================
# Chiffreo - Configuration PRODUCTION
# ============================================

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chiffreo
DB_USER=chiffreo_user
DB_PASS=CHANGE_ME_IN_PRODUCTION

# OpenAI API
OPENAI_API_KEY=CHANGE_ME_IN_PRODUCTION

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://chiffreo.com
# Chemin de base (vide en prod = racine du domaine)
APP_BASE_PATH=

# Limites
RATE_LIMIT_PER_MINUTE=30
MAX_UPLOAD_SIZE_MB=10

# Stockage
STORAGE_PATH=storage

# Push Notifications (VAPID keys)
VAPID_PUBLIC_KEY=CHANGE_ME_IN_PRODUCTION
VAPID_PRIVATE_KEY=CHANGE_ME_IN_PRODUCTION
VAPID_SUBJECT=mailto:contact@chiffreo.com
